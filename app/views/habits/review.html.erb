<div class="container">

  <div class="header-bar">
    <!-- 左：戻るボタン -->
    <div class="header-left">
      <%= link_to "← 学習記録一覧",
          study_logs_path,
          class: "btn btn-back" %>
    </div>

    <!-- 中央：タイトル -->
    <div class="header-center">
      <h1 class="page-title">習慣の振り返り</h1>
    </div>

    <!-- 右：ここは空でもOK（ベルやログアウト用にスペース確保） -->
    <div class="header-right">
      <!-- 今は何も入れない -->
    </div>
  </div> <!-- header-bar 終了 -->

  <!-- フィルター -->
  <div class="filter-card">
    <%= form_with url: review_habits_path, method: :get, local: true do |f| %>
      <div class="habit-filter-form">
        <%= f.label :category, "カテゴリ" %>
        <%= f.select :category,
            options_for_select(@categories, params[:category]),
            include_blank: "すべて",
            class: "select-input" %>

        <%= f.label :status, "達成状況" %>
        <%= f.select :status,
            options_for_select([["すべて", ""], ["完了", "completed"], ["未完", "incomplete"]], params[:status]),
            class: "select-input" %>

        <%= f.submit "表示", class: "btn btn-info" %>
      </div>
    <% end %>
  </div>

  <!-- 達成率 -->
  <div class="completion-card">
    <%= render "completion_rates",
        week_completion_rate: @week_completion_rate,
        month_completion_rate: @month_completion_rate %>
  </div>

  <% @habits_by_date.each do |date, habits| %>
    <h2 class="date-title"><%= date.strftime("%Y/%m/%d") %></h2>

    <div class="table-card">
      <table class="habits-table">
        <thead>
          <tr>
            <th>習慣名</th>
            <th>カテゴリ</th>
            <th>達成状況</th>
            <th>操作</th>
          </tr>
        </thead>
        <tbody>
          <% habits.each do |habit| %>
            <tr id="habit-<%= habit.id %>" class="<%= habit.completed ? 'completed' : 'incomplete' %>">
              <td><%= habit.name %></td>
              <td>
                <span class="category-tag category-<%= habit.category %>">
                  <%= habit.category %>
                </span>
              </td>
              <td class="habit-status"><%= habit.completed ? "✅ 完了" : "❌ 未完" %></td>
              <td>
                <%= button_to (habit.completed ? '完了解除' : '完了'),
                              toggle_complete_habit_path(habit),
                              method: :patch,
                              class: "btn btn-complete" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>

</div>
