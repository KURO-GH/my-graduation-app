<div id="completion-rates">
  <p>今週の達成率: <%= @week_completion_rate %>%</p>
  <div class="completion-bar-bg">
    <div class="week-completion-bar"
         style="width: <%= @week_completion_rate %>%"></div>
  </div>

  <p>今月の達成率: <%= @month_completion_rate %>%</p>
  <div class="completion-bar-bg">
    <div class="month-completion-bar"
         style="width: <%= @month_completion_rate %>%"></div>
  </div>
</div>
