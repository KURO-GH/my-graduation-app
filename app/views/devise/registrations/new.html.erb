<div class="auth-card">
  <h1>新規登録</h1>

  <% if resource.errors.any? %>
    <div class="alert alert-danger">
      <ul>
        <% resource.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>

    <div class="form-group">
      <%= f.label :email, "メールアドレス" %>
      <%= f.email_field :email, class: "form-input" %>
    </div>

    <div class="form-group">
      <%= f.label :password, "パスワード" %>
      <%= f.password_field :password, class: "form-input" %>
    </div>

    <div class="form-group">
      <%= f.label :password_confirmation, "パスワード確認" %>
      <%= f.password_field :password_confirmation, class: "form-input" %>
    </div>

    <%= f.submit '登録する', class: 'btn btn-primary' %>

  <% end %>

  <div class="auth-links">
    <%= link_to "ログインはこちら", new_user_session_path, class: "btn btn-link" %>

    <%= link_to "Googleでログイン",
          user_google_oauth2_omniauth_authorize_path,
          class: "btn btn-google",
          data: { turbo: false } %>
  </div>
</div>
